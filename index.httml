<!DOCTYPE html><html lang="pt-BR"><head><meta charset="UTF-8"/><meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"/><meta name="theme-color" content="#1A1A2E"/><meta name="apple-mobile-web-app-capable" content="yes"/><meta name="apple-mobile-web-app-status-bar-style" content="black-translucent"/><meta name="apple-mobile-web-app-title" content="Calendario"/><title>Calendario 2026</title><style>*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}body{font-family:system-ui,sans-serif;background:#F7F6F2;color:#1A1A2E;min-height:100vh}.topbar{background:#1A1A2E;color:#fff;display:flex;align-items:center;justify-content:space-between;padding:14px 16px;padding-top:calc(14px + env(safe-area-inset-top));position:sticky;top:0;z-index:100}.topbar h1{font-size:18px;font-weight:700}.nav-btns{display:flex;gap:8px}.nb{background:rgba(255,255,255,.15);border:none;color:#fff;width:36px;height:36px;border-radius:50%;font-size:22px;cursor:pointer;display:flex;align-items:center;justify-content:center}.mh{background:#1A1A2E;color:#fff;text-align:center;padding:4px 20px 16px}.mt{font-size:28px;font-weight:800;letter-spacing:1px}.ms{font-size:11px;color:rgba(255,255,255,.4);letter-spacing:2px;text-transform:uppercase;margin-top:2px}.dr{display:grid;grid-template-columns:repeat(7,1fr);background:#16213E}.dc{text-align:center;padding:8px 0;font-size:10px;font-weight:700;letter-spacing:1px;color:rgba(255,255,255,.5);text-transform:uppercase}.dc.wk{color:#E94560}.cg{display:grid;grid-template-columns:repeat(7,1fr);gap:1px;background:#E5E2DB}.cell{background:#fff;min-height:90px;padding:6px;cursor:pointer;display:flex;flex-direction:column;position:relative}.cell.wknd{background:#fff5f5}.cell.oth{background:#f3f6fa}.cell.tod{background:#e8f4ff}.cell.hn::after{content:'';position:absolute;bottom:4px;right:4px;width:6px;height:6px;border-radius:50%;background:#E94560}.dn{font-size:20px;font-weight:800;line-height:1;color:#1A1A2E}.cell.wknd .dn{color:#E94560}.cell.oth .dn{color:#B0BAC6;font-size:16px}.dl{font-size:9px;color:#B0BAC6;text-transform:uppercase;letter-spacing:1px;margin-bottom:2px}.dp{font-size:10px;color:#9BA3AF;margin-top:4px;line-height:1.4;overflow:hidden;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;flex:1}.ov{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:200;align-items:flex-end}.ov.open{display:flex}.mod{background:#fff;width:100%;border-radius:24px 24px 0 0;padding-bottom:env(safe-area-inset-bottom);max-height:85vh;display:flex;flex-direction:column}.mhan{width:40px;height:4px;background:#E5E2DB;border-radius:2px;margin:12px auto 0}.mhd{display:flex;align-items:center;justify-content:space-between;padding:14px 20px 12px;border-bottom:1px solid #E5E2DB}.mtit{font-size:22px;font-weight:800}.msub{font-size:12px;color:#9BA3AF;margin-top:2px}.mcl{background:#F7F6F2;border:none;width:32px;height:32px;border-radius:50%;font-size:20px;cursor:pointer;color:#9BA3AF}.mbd{padding:14px 20px;flex:1;overflow-y:auto}.ta{width:100%;min-height:160px;border:1.5px solid #E5E2DB;border-radius:14px;padding:14px;font-family:system-ui;font-size:15px;line-height:1.7;color:#1A1A2E;background:#F7F6F2;resize:none;outline:none}.ma{display:flex;gap:10px;padding:12px 20px 16px;border-top:1px solid #E5E2DB}.bsv{flex:1;background:#1A1A2E;color:#fff;border:none;border-radius:14px;padding:14px;font-size:15px;font-weight:700;cursor:pointer}.bcl{background:#F7F6F2;color:#E94560;border:1.5px solid #E5E2DB;border-radius:14px;padding:14px 16px;font-size:14px;cursor:pointer}.ft{text-align:center;padding:16px;font-size:11px;color:#9BA3AF}</style></head><body><div class="topbar"><div class="nav-btns"><button class="nb" id="pv">&#8249;</button><button class="nb" id="nx">&#8250;</button></div><h1 id="tt">Calendario</h1><button class="nb" id="td" style="font-size:11px;font-weight:800">HOJE</button></div><div class="mh"><div class="mt" id="mt">—</div><div class="ms">Calendario · Anotacoes</div></div><div class="dr"><div class="dc">Seg</div><div class="dc">Ter</div><div class="dc">Qua</div><div class="dc">Qui</div><div class="dc">Sex</div><div class="dc wk">Sab</div><div class="dc wk">Dom</div></div><div class="cg" id="cg"></div><div class="ft">Toque em qualquer dia para anotar</div><div class="ov" id="ov"><div class="mod"><div class="mhan"></div><div class="mhd"><div><div class="mtit" id="mtit">—</div><div class="msub" id="msub"></div></div><button class="mcl" id="mc">x</button></div><div class="mbd"><textarea class="ta" id="ta" placeholder="Escreva suas anotacoes..."></textarea></div><div class="ma"><button class="bcl" id="bc">Apagar</button><button class="bsv" id="bs">Salvar</button></div></div></div><script>var MP=["Janeiro","Fevereiro","Marco","Abril","Maio","Junho","Julho","Agosto","Setembro","Outubro","Novembro","Dezembro"];var MS=["jan","fev","mar","abr","mai","jun","jul","ago","set","out","nov","dez"];var DW=["Dom","Seg","Ter","Qua","Qui","Sex","Sab"];var cY=2026,cM=4,aK=null;function gn(y,m,d){return localStorage.getItem("n_"+y+"_"+m+"_"+d)||"";}function sn(y,m,d,v){if(v)localStorage.setItem("n_"+y+"_"+m+"_"+d,v);else localStorage.removeItem("n_"+y+"_"+m+"_"+d);}function isT(y,m,d){var t=new Date();return t.getFullYear()===y&&t.getMonth()===m&&t.getDate()===d;}function build(){var y=cY,m=cM;document.getElementById("mt").textContent=MP[m].toUpperCase()+"  "+y;document.getElementById("tt").textContent=MP[m]+" "+y;var g=document.getElementById("cg");g.innerHTML="";var fd=new Date(y,m,1).getDay();var off=fd===0?6:fd-1;var dim=new Date(y,m+1,0).getDate();var dip=new Date(y,m,0).getDate();var total=Math.ceil((off+dim)/7)*7;for(var i=0;i<total;i++){var c=document.createElement("div");c.className="cell";var col=i%7;var isW=col>=5;var cy=y,cm=m,cd,lb="",isO=false;if(i<off){cm=(m+11)%12;cy=cm===11?y-1:y;cd=dip-off+i+1;lb=MS[cm];isO=true;}else if(i>=off+dim){cm=(m+1)%12;cy=m===11?y+1:y;cd=i-off-dim+1;lb=MS[cm];isO=true;}else{cd=i-off+1;}if(isO)c.classList.add("oth");else if(isW)c.classList.add("wknd");if(isT(cy,cm,cd)&&!isO)c.classList.add("tod");var note=gn(cy,cm,cd);if(note)c.classList.add("hn");var html="";if(isO)html+='<div class="dl">'+lb+'</div>';html+='<div class="dn">'+cd+'</div>';if(note)html+='<div class="dp">'+note.replace(/\n/g,"<br>")+'</div>';c.innerHTML=html;(function(cy2,cm2,cd2){c.addEventListener("click",function(){openM(cy2,cm2,cd2);});})(cy,cm,cd);g.appendChild(c);}}function openM(y,m,d){aK={y:y,m:m,d:d};document.getElementById("mtit").textContent=DW[new Date(y,m,d).getDay()]+", "+d+" de "+MP[m];document.getElementById("msub").textContent=y;document.getElementById("ta").value=gn(y,m,d);document.getElementById("ov").classList.add("open");}function closeM(){document.getElementById("ov").classList.remove("open");aK=null;}document.getElementById("bs").addEventListener("click",function(){if(!aK)return;sn(aK.y,aK.m,aK.d,document.getElementById("ta").value.trim());closeM();build();});document.getElementById("bc").addEventListener("click",function(){document.getElementById("ta").value="";});document.getElementById("mc").addEventListener("click",closeM);document.getElementById("ov").addEventListener("click",function(e){if(e.target===this)closeM();});document.getElementById("pv").addEventListener("click",function(){cM--;if(cM<0){cM=11;cY--;}build();});document.getElementById("nx").addEventListener("click",function(){cM++;if(cM>11){cM=0;cY++;}build();});document.getElementById("td").addEventListener("click",function(){var t=new Date();cY=t.getFullYear();cM=t.getMonth();build();});build();</script></body></html>